  },
  "Watchlist": {   
    "Source": "Local",
    "FeatureVersion": "0.1",
    "SyncIntervalSeconds": 20,
    "FullRefreshMinutes": 10,
    "UsePerItemThreshold": true
  },
  "Enrollment": {
    "CgiPath": "/cgi-bin/adam.cgi",
    "AppName": "FaceBestshotApp",
    "AppDataType": 3,
    "FeatureVersion": "0.1",
    "AppDataTemplateBase64": "",
   "AppDataTemplateFile": "tmp/sample_s_appData.txt",
    "MaxJpegBytes": 200000,
    "MinResizeDimension": 64,
    "CgiTraceLogPath": "logs/enroll-cgi.log",
    "ErrorLogPath": "logs/enroll-error.log",
    "UseHttps": false,
    "HttpPort": 80,
    "TimeoutSeconds": 30
  },
  "FaceDetection": {
    "Enabled": true,
    "ModelPath": "models/scrfd.onnx",
    "InputSize": 640,
    "ScoreThreshold": 0.5,
    "NmsThreshold": 0.4,
    "MaxFaces": 10,
    "MinFaceSize": 48,
    "MarginRatio": 0.25,
    "OutputSize": 100,
    "JpegQuality": 90,
    "AlignEnabled": true,
    "AlignScale": 0.9,
    "SwapRB": true,
    "Mean": [127.5, 127.5, 127.5],
    "Std": [128, 128, 128]
  },
  "Matching": {
    "Similarity": 0.7,
    "Score": 0.3
  },
  "VectorIndex": {
    "Dimension": 0,
    "TopK": 20,
    "HnswM": 16,
    "HnswEfConstruction": 200,
    "HnswEfSearch": 64,
    "AutoRebuildOnMismatch": false,
    "QueryTimeoutSeconds": 5
  },
  "Bestshot": {
    "Enabled": true,
    "RootPath": "bestshots",
    "RetentionDays": 90,
    "StoreKnown": true,
    "StoreUnknown": true,
    "StoreThumb": false,
    "MaxBytes": 18432,
    "CleanupIntervalHours": 12
  },
  "Map": {
    "RootPath": "MapData/maps",
    "MaxImageBytes": 10485760,
    "GeoStyleUrl": "/mapstyles/vietnam-omt-style.json",
    "RoutingBaseUrl": "",
    "ServeLocalAssets": true
  },
  "MapTiles": {
    "MbtilesPath": "MapData/mbtiles/vietnam_openmaptiles.mbtiles",
    "MinZoom": 5,
    "MaxZoom": 14,
    "UseTmsCoordinates": true
  },
  "Routing": {
    "Enabled": true,
    "PbfPath": "MapData/pbf/vietnam-260111.osm.pbf",
    "CachePath": "MapData/pbf/routerdb.cache",
    "Profile": "car"
  },
  "Webhook": {
    "HmacSecret": "",
    "SendKnown": true,
    "FaceCooldownSeconds": 60,
    "TimeoutSeconds": 5,
    "MaxRetries": 5,
    "CircuitBreakerFailures": 5,
    "CircuitBreakerBreakSeconds": 60
  },
  "SubscriberService": {
    "Enabled": true,
    "HmacSecret": "",
    "RequireSignature": false,
    "MaxItems": 50,
    "DedupMinutes": 5
  },
  "Workers": {
    "MatchDegreeOfParallelism": 2,
    "WebhookDegreeOfParallelism": 4
  },
  "PipelineWatchdog": {
    "IntervalSeconds": 15,
    "QueueLogIntervalSeconds": 60,
    "StallTimeoutSeconds": 120,
    "StallGraceSeconds": 30,
    "MaxStallCount": 2,
    "AutoRestartOnStall": true
