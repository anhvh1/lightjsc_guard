  "Encryption": {
    "Base64Key": "hqD5aWYT2p2ijoUTXUKV5N77M7yVvFUkQJfXDoOPDTM="
  },
  "Rtsp": {
    "KeepAliveSeconds": 15,
    "ConnectTimeoutSeconds": 10,
    "ReceiveTimeoutSeconds": 30,
    "ReconnectMinSeconds": 1,
    "ReconnectMaxSeconds": 30,
    "MaxMetadataFrameBytes": 1048576
  },
  "Ingest": {
    "ChannelCapacity": 2048,
    "BestShotOnly": true,
    "DedupWindowMs": 1500,
    "MinFeatureDimension": 256,
    "MaxEventTimeSkewMinutes": 10,
